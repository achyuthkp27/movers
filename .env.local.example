# Environment Configuration — SwiftMove®
# Copy this file to .env.local and fill in your actual values

# ── API & Services ────────────────────────
NEXT_PUBLIC_API_URL=https://api.swiftmove.local
NEXT_PUBLIC_ANALYTICS_ID=G_XXXXXXXXXXXX

# ── Contact Information ────────────────────
NEXT_PUBLIC_PHONE=+1-800-123-4567
NEXT_PUBLIC_EMAIL=support@swiftmove.local
NEXT_PUBLIC_WHATSAPP_NUMBER=1800123456

# ── Business Information ──────────────────
NEXT_PUBLIC_BUSINESS_NAME=SwiftMove®
NEXT_PUBLIC_BUSINESS_URL=https://swiftmove.local

# ── Social Media ───────────────────────────
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/swiftmove
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/swiftmove
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/swiftmove

# ── Feature Flags ──────────────────────────
NEXT_PUBLIC_ENABLE_CHATBOT=true
NEXT_PUBLIC_ENABLE_ANIMATIONS=true
NEXT_PUBLIC_ENABLE_TRACKING=true
